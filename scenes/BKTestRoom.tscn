[sub_resource type="Shader" id="checker_shader"]
code = "shader_type spatial;
render_mode unshaded;

void fragment() {
	vec2 uv_s = UV * 50.0;
	float checker = mod(floor(uv_s.x) + floor(uv_s.y), 2.0);
	ALBEDO = mix(vec3(0.72), vec3(0.52), checker);
}
"

[sub_resource type="ShaderMaterial" id="checker_mat"]
