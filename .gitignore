# ===========================================
# M.E.R.L.I.N. Project .gitignore
# Updated: 2026-02-22
# ===========================================

# -------------------------------------------
# Godot 4+ Engine
# -------------------------------------------
.godot/
*.import
export_presets.cfg
/android/

# -------------------------------------------
# IDE & Editors
# -------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
*.code-workspace
.idea/
*.sublime-project
*.sublime-workspace

# -------------------------------------------
# Operating System
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk
nul

# -------------------------------------------
# LLM Models & Binaries (large files)
# -------------------------------------------
*.gguf
*.bin
*.safetensors
addons/merlin_llm/bin/*
!addons/merlin_llm/bin/.gdignore
addons/merlin_llm/models/*.gguf
addons/merlin_llm/models/*.bin
!addons/merlin_llm/models/.gdignore

# -------------------------------------------
# Native Build (GDExtension)
# -------------------------------------------
native/build/
native/godot-cpp/
native/llama.cpp/
*.so
*.dll
*.dylib
*.a
*.lib
*.obj
*.o

# -------------------------------------------
# Node.js / NPM
# -------------------------------------------
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# -------------------------------------------
# Python
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.env/

# -------------------------------------------
# Secrets & Credentials (NEVER COMMIT)
# -------------------------------------------
.env
.env.*
*.env
*credentials*
*secret*
*password*
*.pem
*.key
api_keys.json

# -------------------------------------------
# Temporary & Backup Files
# -------------------------------------------
*.tmp
*.TMP
*.temp
*.bak
*.backup
*.swp
*.swo
*~
\#*\#
.fuse_hidden*
tmp/
.tmp_*
tmpgodot_*
temp_*

# -------------------------------------------
# Claude Code Artifacts
# -------------------------------------------
UsersPGNK2128*
$OUT

# -------------------------------------------
# Logs
# -------------------------------------------
*.log
logs/
*.log.*

# -------------------------------------------
# Large Assets (optional - uncomment if needed)
# -------------------------------------------
# *.psd
# *.blend
# *.blend1
# *.xcf
# *.raw
# Assets/raw/

# -------------------------------------------
# GameObserver Captures (runtime screenshots + state)
# -------------------------------------------
tools/autodev/captures/*.png
tools/autodev/captures/*.json
!tools/autodev/captures/.gitkeep

# -------------------------------------------
# Project-Specific Ignores
# -------------------------------------------
# Temporary Excel processing folder
tmp_xlsx/

# Large files (GitHub limit 100MB)
*.pdb
archive/artifacts/*.zip
archive/artifacts/*.tgz
archive/artifacts/*.tar.gz

# Benchmark results (one-time data dumps)
tools/benchmark_results_*.json
tools/raw_test_*.json
tools/test_brain_pool_results_*.json

# Node.js build artifacts (tools/)
tools/node_modules/
tools/.sharp/

# Archive folder (deprecated files, review before commit)
# archive/

# Test outputs
tests/output/
*.test.tmp

# ===========================================
# END
