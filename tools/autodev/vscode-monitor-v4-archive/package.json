{
  "name": "autodev-monitor-v4",
  "displayName": "M.E.R.L.I.N. Remote",
  "description": "VS Code panel — GPU training, chat, agent roster, Claude sessions monitor",
  "version": "13.0.0",
  "publisher": "merlin-local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autodev-v4-sidebar",
          "title": "M.E.R.L.I.N. Remote",
          "icon": "media/autodev-icon.svg"
        }
      ]
    },
    "views": {
      "autodev-v4-sidebar": [
        {
          "type": "webview",
          "id": "autodev-v4.remoteTrain",
          "name": "GPU Train + Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "autodev-v4.remoteTrain.open",
        "title": "MERLIN Remote: Open Left Panel"
      },
      {
        "command": "autodev-v4.remoteTrain.refresh",
        "title": "MERLIN Remote: Refresh"
      },
      {
        "command": "autodev-v4.remoteTrain.configure",
        "title": "MERLIN Remote: Configure"
      },
      {
        "command": "autodev-v4.remoteTrain.doctor",
        "title": "MERLIN Remote: Doctor"
      },
      {
        "command": "autodev-v4.remoteTrain.setup",
        "title": "MERLIN Remote: Setup"
      },
      {
        "command": "autodev-v4.remoteTrain.submit",
        "title": "MERLIN Remote: Submit"
      },
      {
        "command": "autodev-v4.remoteTrain.status",
        "title": "MERLIN Remote: Status"
      },
      {
        "command": "autodev-v4.remoteTrain.download",
        "title": "MERLIN Remote: Download"
      },
      {
        "command": "autodev-v4.remoteTrain.openKaggle",
        "title": "MERLIN Remote: Open Kaggle"
      }
    ],
    "configuration": {
      "title": "M.E.R.L.I.N. Remote",
      "properties": {
        "autodev-v4.remoteTrain.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used for remote Kaggle orchestration."
        },
        "autodev-v4.remoteTrain.kaggleUsername": {
          "type": "string",
          "default": "",
          "description": "Kaggle username used to create and monitor kernels."
        },
        "autodev-v4.remoteTrain.kernelSlug": {
          "type": "string",
          "default": "merlin-remote-train",
          "description": "Kaggle kernel slug."
        },
        "autodev-v4.remoteTrain.kernelTitle": {
          "type": "string",
          "default": "MERLIN Remote LoRA Training",
          "description": "Kaggle kernel title."
        },
        "autodev-v4.remoteTrain.testModel": {
          "type": "string",
          "default": "meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo",
          "description": "Model used for chat test."
        },
        "autodev-v4.remoteTrain.testEndpoint": {
          "type": "string",
          "default": "https://api.together.xyz/v1/chat/completions",
          "description": "Optional OpenAI-compatible endpoint URL for remote inference (base /v1 or /chat/completions). If empty, fallback to local Ollama."
        },
        "autodev-v4.remoteTrain.testApiKey": {
          "type": "string",
          "default": "",
          "description": "Optional API key for testEndpoint."
        }
      }
    }
  }
}
