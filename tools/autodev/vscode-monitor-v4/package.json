{
  "name": "autodev-monitor-v4",
  "displayName": "M.E.R.L.I.N. Orchestrator",
  "description": "Godot Orchestrator — Autonomous Game Studio (48 agents, 5 studio modes)",
  "version": "6.0.0",
  "publisher": "merlin-local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:project.godot"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autodev-v4-sidebar",
          "title": "MERLIN Orchestrator",
          "icon": "media/autodev-icon.svg"
        }
      ]
    },
    "views": {
      "autodev-v4-sidebar": [
        {
          "type": "webview",
          "id": "autodev-v4.gameControl",
          "name": "Game Control"
        },
        {
          "type": "webview",
          "id": "autodev-v4.liveView",
          "name": "Live View"
        },
        {
          "type": "webview",
          "id": "autodev-v4.commands",
          "name": "Commands"
        },
        {
          "type": "webview",
          "id": "autodev-v4.diagnostics",
          "name": "Diagnostics"
        },
        {
          "type": "webview",
          "id": "autodev-v4.overnight",
          "name": "Overnight"
        },
        {
          "type": "webview",
          "id": "autodev-v4.studio",
          "name": "Studio"
        }
      ]
    },
    "commands": [
      {
        "command": "autodev-v4.refresh",
        "title": "Orchestrator: Refresh All Panels"
      },
      {
        "command": "autodev-v4.launchGame",
        "title": "Godot: Launch Game (Bootstrap)"
      },
      {
        "command": "autodev-v4.killGodot",
        "title": "Godot: Kill Process"
      },
      {
        "command": "autodev-v4.validate",
        "title": "Godot: Run validate.bat"
      },
      {
        "command": "autodev-v4.sendCommand",
        "title": "Orchestrator: Send Command to Game"
      }
    ],
    "keybindings": [
      {
        "command": "autodev-v4.launchGame",
        "key": "f5",
        "when": "resourceExtname == .gd || resourceExtname == .tscn"
      },
      {
        "command": "autodev-v4.killGodot",
        "key": "shift+f5"
      }
    ]
  }
}
