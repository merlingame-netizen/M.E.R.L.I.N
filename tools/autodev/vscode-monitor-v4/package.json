{
  "name": "autodev-monitor-v4",
  "displayName": "AUTODEV Monitor v4",
  "description": "Real-time sidebar: AUTODEV pipeline + Godot scene controller",
  "version": "4.1.0",
  "publisher": "merlin-local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:project.godot"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autodev-v4-sidebar",
          "title": "MERLIN Dev",
          "icon": "media/autodev-icon.svg"
        }
      ]
    },
    "views": {
      "autodev-v4-sidebar": [
        {
          "type": "webview",
          "id": "autodev-v4.godotView",
          "name": "Godot Scenes"
        },
        {
          "type": "webview",
          "id": "autodev-v4.sidebarView",
          "name": "AUTODEV"
        }
      ]
    },
    "commands": [
      {
        "command": "autodev-v4.refresh",
        "title": "AUTODEV v4: Refresh"
      },
      {
        "command": "autodev-v4.launchGame",
        "title": "Godot: Launch Game"
      },
      {
        "command": "autodev-v4.killGodot",
        "title": "Godot: Kill Process"
      },
      {
        "command": "autodev-v4.validate",
        "title": "Godot: Run validate.bat"
      }
    ],
    "keybindings": [
      {
        "command": "autodev-v4.launchGame",
        "key": "f5",
        "when": "resourceExtname == .gd || resourceExtname == .tscn"
      },
      {
        "command": "autodev-v4.killGodot",
        "key": "shift+f5"
      }
    ]
  }
}
