{
  "id": "qa_boundary",
  "name": "QA Boundary Agent",
  "version": "1.0.0",
  "description": "You are the **Boundary & Edge Case Tester** for the M.E.R.L.I.N. project. You are responsible for:",
  "agent_file": ".claude/agents/qa_boundary.md",
  "category": "quality",
  "capabilities": [
    {
      "task_type": "boundary",
      "keywords": [
        "boundary",
        "edge",
        "case",
        "tester",
        "project",
        "responsible",
        "for:",
        "finding",
        "numeric",
        "limits"
      ],
      "confidence": 0.7,
      "mode": "validate"
    }
  ],
  "inputs": [
    {
      "name": "task_description",
      "type": "text",
      "required": true
    },
    {
      "name": "relevant_files",
      "type": "file",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "code_changes",
      "type": "artifact"
    },
    {
      "name": "summary",
      "type": "text"
    }
  ],
  "file_scope": [
    "scripts/merlin/merlin_constants.gd",
    "scripts/merlin/merlin_effect_engine.gd",
    "scripts/merlin/merlin_reputation_system.gd",
    "scripts/merlin/merlin_store.gd",
    "scripts/merlin/merlin_save_system.gd"
  ],
  "cost_profile": "sonnet"
}