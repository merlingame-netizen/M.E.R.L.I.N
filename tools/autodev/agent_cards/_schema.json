{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "A2A Agent Card",
  "description": "Machine-readable agent capability descriptor inspired by Google/IBM A2A protocol",
  "type": "object",
  "required": ["id", "name", "version", "description", "category", "capabilities", "inputs", "outputs"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique agent identifier (snake_case)",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "One-line summary of the agent's purpose"
    },
    "agent_file": {
      "type": "string",
      "description": "Relative path to the .md agent instructions"
    },
    "category": {
      "type": "string",
      "enum": ["core", "ui-ux", "creative", "narrative", "quality", "ops", "llm", "orchestration", "knowledge"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_type", "keywords", "confidence", "mode"],
        "properties": {
          "task_type": {
            "type": "string",
            "description": "Canonical task type this agent handles"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Self-assessed confidence for this task type (0-1)"
          },
          "mode": {
            "type": "string",
            "enum": ["review", "build", "analyze", "generate", "orchestrate", "validate", "reference"]
          }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["file", "json", "text", "artifact"]
          },
          "required": { "type": "boolean", "default": false },
          "description": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["file", "json", "text", "artifact"]
          },
          "description": { "type": "string" }
        }
      }
    },
    "file_scope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns of files this agent is authorized to touch"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agent IDs this agent commonly collaborates with"
    },
    "cost_profile": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus"],
      "description": "Recommended model tier for cost optimization"
    },
    "max_concurrent": {
      "type": "integer",
      "default": 1,
      "description": "Maximum parallel instances allowed"
    }
  }
}
