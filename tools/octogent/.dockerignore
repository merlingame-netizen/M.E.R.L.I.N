# ────────────────────────────────────────────────────────────────────────
# Excluded from the Docker build context. Smaller context = faster builds
# + no risk of leaking host artifacts into the image.
# ────────────────────────────────────────────────────────────────────────

# Local node_modules — recompiled inside the builder stage anyway.
node_modules
**/node_modules

# Build outputs — regenerated by pnpm build inside the builder stage.
dist
**/dist
.turbo
**/.turbo

# Octogent runtime state — must NEVER end up baked into the image.
.octogent
**/.octogent

# Git metadata — not needed at runtime, would balloon context size.
.git
.gitignore

# IDE / editor cruft.
.vscode
.idea
*.swp
*.tmp
*.log

# Host docs that aren't needed at runtime.
docs
README.md

# This Docker config itself isn't needed inside the image.
Dockerfile
docker-compose.yml
.dockerignore
start-wsl.sh
