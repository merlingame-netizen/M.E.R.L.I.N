; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MERLIN"
run/main_scene="res://scenes/IntroCeltOS.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/show_image=false
boot_splash/bg_color=Color(0.02, 0.04, 0.02, 1)

[autoload]

GameManager="*res://scripts/game_manager.gd"
MerlinAI="*res://addons/merlin_ai/merlin_ai.gd"
MerlinBackdrop="*res://scripts/merlin_backdrop.gd"
ScreenFrame="*res://scripts/autoload/screen_frame.gd"
ScreenEffects="*res://scripts/autoload/ScreenEffects.gd"
SceneSelector="*res://scripts/autoload/SceneSelector.gd"
LocaleManager="*res://scripts/autoload/LocaleManager.gd"
I18nRegistry="*res://scripts/autoload/i18n_registry.gd"
SFXManager="*res://scripts/autoload/SFXManager.gd"
MerlinVisual="*res://scripts/autoload/merlin_visual.gd"
PixelTransition="*res://scripts/autoload/pixel_transition.gd"
PixelContentAnimator="*res://scripts/autoload/pixel_content_animator.gd"
WorldMapSystem="*res://scripts/autoload/world_map_system.gd"
MusicManager="*res://scripts/autoload/music_manager.gd"
GameTimeManager="*res://scripts/autoload/game_time_manager.gd"
InputAdapter="*res://scripts/autoload/input_adapter.gd"
PlatformManager="*res://scripts/autoload/platform_manager.gd"
ScreenDither="*res://scripts/ui/screen_dither_layer.gd"
GameDebugServer="*res://scripts/test/game_debug_server.gd"
DayNightManager="*res://scripts/autoload/day_night_manager.gd"
MerlinResponsive="*res://scripts/autoload/merlin_responsive.gd"
GameFlow="*res://scripts/core/game_flow_controller.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=5

[editor_plugins]

enabled=PackedStringArray("res://addons/error_clipboard_dock/plugin.cfg", "res://addons/gd_script_deployer/plugin.cfg", "res://addons/godot_mcp/plugin.cfg")

[gui]

theme/custom="res://themes/merlin_theme.tres"

[internationalization]

locale/translations=PackedStringArray("res://data/i18n/translations.csv")
locale/fallback="fr"

[merlin_llm]

log_enabled=true
log_verbose=true
log_path="user://merlin_llm/merlin.log"
allow_native_in_editor=true
require_native=true
low_spec_mode=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.039, 0.039, 0.071, 1)
