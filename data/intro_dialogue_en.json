[
  {
    "id": "welcome",
    "merlin": "...\n\nOh?\n\nYou're here already?",
    "next": "merlin_surprise"
  },

  {
    "id": "merlin_surprise",
    "merlin": "I wasn't expecting you so soon, Traveler.\n\nThe mists guided you faster than I thought.",
    "next": "merlin_intro"
  },

  {
    "id": "merlin_intro",
    "merlin": "I am Merlin.\n\nEnchanter. Keeper of thresholds. Weaver of mists.\n\nThis place is my lair... and you are welcome here.",
    "next": "merlin_lair"
  },

  {
    "id": "merlin_lair",
    "merlin": "Here, time flows differently.\n\nThe walls breathe. The stones whisper.\n\nAnd I... I keep watch.",
    "next": "merlin_explain"
  },

  {
    "id": "merlin_explain",
    "merlin": "You're wondering why you're here?\n\nThe moor called you. Not me.\n\nBut now that you're here...",
    "next": "mission_intro"
  },

  {
    "id": "mission_intro",
    "merlin": "I need a Traveler.\n\nSomeone to walk between worlds.\n\nSomeone to reweave what is unraveling.",
    "next": "mission_detail"
  },

  {
    "id": "mission_detail",
    "merlin": "The balance is faltering, Traveler.\n\nFour forces pull on the veil: Vigor, Spirit, Favor, Resources.\n\nIf one collapses... everything follows.",
    "next": "mission_ask"
  },

  {
    "id": "mission_ask",
    "merlin": "Your mission?\n\nSurvive. Balance. Choose.\n\nEach card will be a step. Each choice, a consequence.",
    "choices": {
      "FORCE": [
        {"id": "f_accept", "text": "I'm ready.", "next": "greet", "deltas": {"traits": {"courage": 1}, "verbs": {"FORCE": 1}}, "hooks": ["acts_fast"]},
        {"id": "f_challenge", "text": "Show me what awaits.", "next": "greet", "deltas": {"traits": {"orgueil": 1}, "verbs": {"FORCE": 1}}, "hooks": ["demands_proof"]}
      ],
      "LOGIQUE": [
