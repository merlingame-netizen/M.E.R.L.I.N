# GBNF Grammar for TRIADE Card JSON — M.E.R.L.I.N. Phase 44
# Forces LLM to produce valid JSON matching the card schema.
# Effects: DAMAGE_LIFE, HEAL_LIFE, ADD_KARMA, ADD_SOUFFLE
# Exactly 3 options: left, center, right

root ::= ws "{" ws text-kv "," ws speaker-kv "," ws options-kv ws "}" ws

text-kv    ::= "\"text\"" ws ":" ws string
speaker-kv ::= "\"speaker\"" ws ":" ws "\"merlin\""
options-kv ::= "\"options\"" ws ":" ws "[" ws option "," ws option "," ws option ws "]"

option     ::= "{" ws label-kv "," ws effects-kv ws "}"

label-kv   ::= "\"label\"" ws ":" ws string
effects-kv ::= "\"effects\"" ws ":" ws "[" ws effect ws "]"

effect     ::= "{" ws type-kv "," ws amount-kv ws "}"
type-kv    ::= "\"type\"" ws ":" ws effect-type
amount-kv  ::= "\"amount\"" ws ":" ws number

effect-type ::= "\"DAMAGE_LIFE\"" | "\"HEAL_LIFE\"" | "\"ADD_KARMA\"" | "\"ADD_SOUFFLE\""
number      ::= [0-9] [0-9]?

# String: allows any printable character except unescaped quotes/backslashes
string ::= "\"" char* "\""
char   ::= [^"\\\x00-\x1f] | "\\" ["\\/bfnrt]
ws     ::= [ \t\n]*
